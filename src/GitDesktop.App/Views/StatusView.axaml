<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GitDesktop.App.ViewModels"
             xmlns:conv="using:GitDesktop.App.Converters"
             x:Class="GitDesktop.App.Views.StatusView"
             x:DataType="vm:StatusViewModel">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Branch info header -->
        <Border Grid.Row="0" Background="{DynamicResource ThemePanelBackground}" Padding="12,8">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBlock Text="Branch:" Foreground="{DynamicResource ThemeSecondaryText}"
                           FontSize="{DynamicResource AppFontSize}"
                           VerticalAlignment="Center"/>
                <TextBlock Text="{Binding CurrentBranch}" FontWeight="Bold"
                           FontSize="{DynamicResource AppFontSize}"
                           Foreground="{DynamicResource ThemeBranchColor}"
                           VerticalAlignment="Center"/>
                <TextBlock Text="{Binding UpstreamBranch, StringFormat='↑ {0}'}"
                           Foreground="{DynamicResource ThemeSecondaryText}"
                           FontSize="{DynamicResource AppFontSize}"
                           VerticalAlignment="Center"
                           IsVisible="{Binding UpstreamBranch, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                <TextBlock Text="{Binding AheadCount, StringFormat='▲{0}'}"
                           Foreground="{DynamicResource ThemeSyntaxString}" FontSize="{DynamicResource AppFontSize}"
                           VerticalAlignment="Center"
                           IsVisible="{Binding AheadCount, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                <TextBlock Text="{Binding BehindCount, StringFormat='▼{0}'}"
                           Foreground="{DynamicResource ThemeRemovedForeground}"
                           FontSize="{DynamicResource AppFontSize}"
                           VerticalAlignment="Center"
                           IsVisible="{Binding BehindCount, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                <Button Content="↻ Refresh" Command="{Binding RefreshCommand}"
                        FontSize="{DynamicResource AppFontSize}"
                        HorizontalAlignment="Right" Margin="16,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- Main content: file lists (top) + diff panel (bottom) -->
        <Grid Grid.Row="1" RowDefinitions="*,Auto,200">

            <!-- Three-panel file lists -->
            <Grid Grid.Row="0" ColumnDefinitions="*,*,*">

                <!-- Staged files -->
                <DockPanel Grid.Column="0" Margin="8">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,4">
                        <TextBlock Text="Staged" FontWeight="Bold"
                                   Foreground="{DynamicResource ThemeBranchColor}"
                                   FontSize="{DynamicResource AppFontSize}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding StagedFiles.Count, StringFormat='({0})'}"
                                   Foreground="{DynamicResource ThemeSecondaryText}"
                                   FontSize="{DynamicResource AppFontSize}"/>
                    </StackPanel>
                    <ListBox ItemsSource="{Binding StagedFiles}"
                             SelectedItem="{Binding SelectedFile}"
                             Background="{DynamicResource ThemeContentBackground}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <DockPanel>
                                    <Button DockPanel.Dock="Right" Content="−"
                                            Command="{Binding $parent[UserControl].((vm:StatusViewModel)DataContext).UnstageFileCommand}"
                                            CommandParameter="{Binding}"
                                            FontSize="{DynamicResource AppFontSize}"
                                            ToolTip.Tip="Unstage" Padding="6,2" Margin="4,0,0,0"/>
                                    <TextBlock Text="{Binding Path}" VerticalAlignment="Center"
                                               FontSize="{DynamicResource AppFontSize}"
                                               TextTrimming="CharacterEllipsis"/>
                                </DockPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>

                <!-- Unstaged files -->
                <DockPanel Grid.Column="1" Margin="8">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,4">
                        <TextBlock Text="Unstaged" FontWeight="Bold"
                                   Foreground="{DynamicResource ThemeSyntaxString}"
                                   FontSize="{DynamicResource AppFontSize}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding UnstagedFiles.Count, StringFormat='({0})'}"
                                   Foreground="{DynamicResource ThemeSecondaryText}"
                                   FontSize="{DynamicResource AppFontSize}"/>
                        <Button Content="Stage all" Command="{Binding StageAllCommand}"
                                FontSize="{DynamicResource AppFontSize}"
                                Padding="8,2" Margin="8,0,0,0"/>
                    </StackPanel>
                    <ListBox ItemsSource="{Binding UnstagedFiles}"
                             SelectedItem="{Binding SelectedFile}"
                             Background="{DynamicResource ThemeContentBackground}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <DockPanel>
                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="2">
                                        <Button Content="+"
                                                Command="{Binding $parent[UserControl].((vm:StatusViewModel)DataContext).StageFileCommand}"
                                                CommandParameter="{Binding}"
                                                FontSize="{DynamicResource AppFontSize}"
                                                ToolTip.Tip="Stage" Padding="6,2"/>
                                        <Button Content="✕"
                                                Command="{Binding $parent[UserControl].((vm:StatusViewModel)DataContext).DiscardFileCommand}"
                                                CommandParameter="{Binding}"
                                                FontSize="{DynamicResource AppFontSize}"
                                                ToolTip.Tip="Discard changes"
                                                Foreground="{DynamicResource ThemeRemovedForeground}"
                                                Padding="6,2"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Path}" VerticalAlignment="Center"
                                               FontSize="{DynamicResource AppFontSize}"
                                               TextTrimming="CharacterEllipsis"/>
                                </DockPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>

                <!-- Untracked files -->
                <DockPanel Grid.Column="2" Margin="8">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,4">
                        <TextBlock Text="Untracked" FontWeight="Bold"
                                   Foreground="{DynamicResource ThemeSecondaryText}"
                                   FontSize="{DynamicResource AppFontSize}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding UntrackedFiles.Count, StringFormat='({0})'}"
                                   Foreground="{DynamicResource ThemeSecondaryText}"
                                   FontSize="{DynamicResource AppFontSize}"/>
                    </StackPanel>
                    <ListBox ItemsSource="{Binding UntrackedFiles}"
                             SelectedItem="{Binding SelectedFile}"
                             Background="{DynamicResource ThemeContentBackground}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <DockPanel>
                                    <Button DockPanel.Dock="Right" Content="+"
                                            Command="{Binding $parent[UserControl].((vm:StatusViewModel)DataContext).StageFileCommand}"
                                            CommandParameter="{Binding}"
                                            FontSize="{DynamicResource AppFontSize}"
                                            ToolTip.Tip="Stage" Padding="6,2" Margin="4,0,0,0"/>
                                    <TextBlock Text="{Binding Path}" VerticalAlignment="Center"
                                               FontSize="{DynamicResource AppFontSize}"
                                               TextTrimming="CharacterEllipsis"/>
                                </DockPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>

            </Grid>

            <!-- Diff panel splitter -->
            <GridSplitter Grid.Row="1" Height="4"
                          Background="{DynamicResource ThemeBorderColor}"
                          HorizontalAlignment="Stretch"/>

            <!-- Diff viewer: syntax-highlighted lines for selected file -->
            <Grid Grid.Row="2" RowDefinitions="Auto,*">
                <Border Grid.Row="0"
                        Background="{DynamicResource ThemePanelBackground}" Padding="8,4">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="Diff:" FontWeight="Bold"
                                   FontSize="{DynamicResource AppFontSize}"
                                   Foreground="{DynamicResource ThemePrimaryText}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding SelectedFile.Path}"
                                   FontFamily="Cascadia Code,Consolas,monospace"
                                   FontSize="{DynamicResource AppFontSize}"
                                   Foreground="{DynamicResource ThemeAccentColor}"
                                   VerticalAlignment="Center"
                                   IsVisible="{Binding SelectedFile, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                        <TextBlock Text="(select a file above to view its diff)"
                                   FontSize="{DynamicResource AppFontSize}"
                                   Foreground="{DynamicResource ThemeSecondaryText}"
                                   VerticalAlignment="Center"
                                   IsVisible="{Binding SelectedFile, Converter={x:Static ObjectConverters.IsNull}}"/>
                    </StackPanel>
                </Border>
                <ScrollViewer Grid.Row="1"
                              Background="{DynamicResource ThemeContentBackground}"
                              HorizontalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding DiffLines}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:DiffLineViewModel">
                                <Border Background="{Binding BackgroundKey, Converter={StaticResource ResourceKeyBrushConverter}}"
                                        Padding="0">
                                    <TextBlock Text="{Binding Content}"
                                               Foreground="{Binding ForegroundKey, Converter={StaticResource ResourceKeyBrushConverter}}"
                                               FontFamily="Cascadia Code,Consolas,monospace"
                                               FontSize="{DynamicResource AppFontSize}"
                                               TextWrapping="NoWrap"
                                               Margin="4,0"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

        </Grid>

        <!-- Commit panel -->
        <Border Grid.Row="2" Background="{DynamicResource ThemePanelBackground}" Padding="12,8">
            <Grid RowDefinitions="Auto,Auto,Auto">
                <TextBlock Grid.Row="0" Text="{Binding StatusMessage}"
                           Foreground="{DynamicResource ThemeSecondaryText}"
                           FontSize="{DynamicResource AppFontSizeSmall}" Margin="0,0,0,4"
                           IsVisible="{Binding StatusMessage, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                <TextBox Grid.Row="1" Text="{Binding CommitMessage}"
                         Watermark="Commit message…" Height="60"
                         FontSize="{DynamicResource AppFontSize}"
                         AcceptsReturn="True" TextWrapping="Wrap"/>
                <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8"
                            HorizontalAlignment="Right" Margin="0,6,0,0">
                    <CheckBox Content="Amend" IsChecked="{Binding AmendMode}"
                              FontSize="{DynamicResource AppFontSize}"
                              VerticalAlignment="Center"/>
                    <Button Content="Commit staged changes"
                            FontSize="{DynamicResource AppFontSize}"
                            Command="{Binding CommitCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</UserControl>
