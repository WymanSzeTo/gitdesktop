<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GitDesktop.App.ViewModels"
             x:Class="GitDesktop.App.Views.HistoryView"
             x:DataType="vm:HistoryViewModel">

    <Grid RowDefinitions="Auto,*">

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="#1e1e1e" Padding="12,8">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Commit History" FontWeight="Bold" FontSize="14"
                           VerticalAlignment="Center"/>
                <Button Content="↻ Refresh" Command="{Binding RefreshCommand}" Margin="8,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- Split: commit list on left, diff on right -->
        <Grid Grid.Row="1" ColumnDefinitions="2*,3*">

            <!-- Commit list -->
            <ListBox Grid.Column="0"
                     ItemsSource="{Binding Commits}"
                     SelectedItem="{Binding SelectedCommit}"
                     Background="#1e1e1e">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Spacing="2" Margin="0,2">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="{Binding ShortHash}"
                                           Foreground="#569cd6"
                                           FontFamily="Cascadia Code,Consolas,monospace"
                                           FontSize="12" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding AuthorDate, StringFormat='{}{0:yyyy-MM-dd}'}"
                                           Foreground="#888" FontSize="11"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="{Binding Subject}"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTip.Tip="{Binding Subject}"/>
                            <TextBlock Text="{Binding AuthorName}"
                                       Foreground="#888" FontSize="11"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Diff / commit details -->
            <Grid Grid.Column="1" RowDefinitions="Auto,*">
                <Border Grid.Row="0" Background="#252526" Padding="12,8"
                        IsVisible="{Binding SelectedCommit, Converter={x:Static ObjectConverters.IsNotNull}}">
                    <StackPanel Spacing="4">
                        <TextBlock Text="{Binding SelectedCommit.Subject}"
                                   FontWeight="Bold" TextWrapping="Wrap"/>
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock Text="{Binding SelectedCommit.AuthorName}" Foreground="#4ec9b0"/>
                            <TextBlock Text="{Binding SelectedCommit.AuthorDate, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}"
                                       Foreground="#888"/>
                            <TextBlock Text="{Binding SelectedCommit.Hash}"
                                       Foreground="#569cd6"
                                       FontFamily="Cascadia Code,Consolas,monospace"
                                       FontSize="11"/>
                        </StackPanel>
                        <TextBlock Text="{Binding SelectedCommit.Body}"
                                   TextWrapping="Wrap" Foreground="#ccc"
                                   IsVisible="{Binding SelectedCommit.Body, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                    </StackPanel>
                </Border>
                <ScrollViewer Grid.Row="1" Background="#1e1e1e">
                    <TextBlock Text="{Binding SelectedCommitDiff}"
                               FontFamily="Cascadia Code,Consolas,monospace"
                               FontSize="12" TextWrapping="NoWrap"
                               Margin="8"/>
                </ScrollViewer>
            </Grid>

        </Grid>
    </Grid>
</UserControl>
