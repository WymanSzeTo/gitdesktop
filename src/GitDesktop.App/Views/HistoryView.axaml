<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GitDesktop.App.ViewModels"
             xmlns:conv="using:GitDesktop.App.Converters"
             x:Class="GitDesktop.App.Views.HistoryView"
             x:DataType="vm:HistoryViewModel">

    <Grid RowDefinitions="Auto,*">

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="{DynamicResource ThemePanelBackground}" Padding="12,8">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Commit History" FontWeight="Bold" FontSize="{DynamicResource AppFontSizeLarge}"
                           Foreground="{DynamicResource ThemePrimaryText}"
                           VerticalAlignment="Center"/>
                <Button Content="↻ Refresh" Command="{Binding RefreshCommand}" Margin="8,0,0,0"/>
                <Separator Width="1" Background="{DynamicResource ThemeBorderColor}" Margin="4,0"/>
                <Button Content="Cherry-pick"
                        Command="{Binding CherryPickCommand}"
                        CommandParameter="{Binding SelectedCommit}"
                        ToolTip.Tip="Cherry-pick the selected commit" Padding="6,2"/>
                <Button Content="Revert"
                        Command="{Binding RevertCommand}"
                        CommandParameter="{Binding SelectedCommit}"
                        ToolTip.Tip="Revert the selected commit" Padding="6,2"/>
                <Button Content="Reset"
                        Command="{Binding ResetToCommitCommand}"
                        CommandParameter="{Binding SelectedCommit}"
                        ToolTip.Tip="Reset HEAD to the selected commit (mixed)" Padding="6,2"
                        Foreground="{DynamicResource ThemeRemovedForeground}"/>
                <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource ThemeSecondaryText}"
                           FontSize="{DynamicResource AppFontSizeSmall}"
                           VerticalAlignment="Center" Margin="8,0,0,0"
                           IsVisible="{Binding StatusMessage, Converter={x:Static ObjectConverters.IsNotNull}}"/>
            </StackPanel>
        </Border>

        <!-- Split: commit list on left, diff on right -->
        <Grid Grid.Row="1" ColumnDefinitions="2*,3*">

            <!-- Commit list -->
            <ListBox Grid.Column="0"
                     ItemsSource="{Binding Commits}"
                     SelectedItem="{Binding SelectedCommit}"
                     Background="{DynamicResource ThemeContentBackground}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Spacing="2" Margin="0,2">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="{Binding ShortHash}"
                                           Foreground="{DynamicResource ThemeAccentColor}"
                                           FontFamily="Cascadia Code,Consolas,monospace"
                                           FontSize="{DynamicResource AppFontSizeSmall}" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding AuthorDate, StringFormat='{}{0:yyyy-MM-dd}'}"
                                           Foreground="{DynamicResource ThemeSecondaryText}" FontSize="{DynamicResource AppFontSizeSmall}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="{Binding Subject}"
                                       Foreground="{DynamicResource ThemePrimaryText}"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTip.Tip="{Binding Subject}"/>
                            <TextBlock Text="{Binding AuthorName}"
                                       Foreground="{DynamicResource ThemeSecondaryText}" FontSize="{DynamicResource AppFontSizeSmall}"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Diff / commit details -->
            <Grid Grid.Column="1" RowDefinitions="Auto,*">
                <Border Grid.Row="0" Background="{DynamicResource ThemePanelBackground}" Padding="12,8"
                        IsVisible="{Binding SelectedCommit, Converter={x:Static ObjectConverters.IsNotNull}}">
                    <StackPanel Spacing="4">
                        <TextBlock Text="{Binding SelectedCommit.Subject}"
                                   FontWeight="Bold" TextWrapping="Wrap"
                                   Foreground="{DynamicResource ThemePrimaryText}"/>
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock Text="{Binding SelectedCommit.AuthorName}" Foreground="{DynamicResource ThemeBranchColor}"/>
                            <TextBlock Text="{Binding SelectedCommit.AuthorDate, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}"
                                       Foreground="{DynamicResource ThemeSecondaryText}"/>
                            <TextBlock Text="{Binding SelectedCommit.Hash}"
                                       Foreground="{DynamicResource ThemeAccentColor}"
                                       FontFamily="Cascadia Code,Consolas,monospace"
                                       FontSize="{DynamicResource AppFontSizeSmall}"/>
                            <Border Background="{DynamicResource ThemePanelBackground}"
                                    BorderBrush="{DynamicResource ThemeBorderColor}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="6,1">
                                <TextBlock Text="{Binding DetectedDiffLanguage}"
                                           Foreground="{DynamicResource ThemeSecondaryText}"
                                           FontSize="{DynamicResource AppFontSizeSmall}"/>
                            </Border>
                        </StackPanel>
                        <TextBlock Text="{Binding SelectedCommit.Body}"
                                   TextWrapping="Wrap" Foreground="{DynamicResource ThemePrimaryText}"
                                    IsVisible="{Binding SelectedCommit.Body, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                    </StackPanel>
                </Border>
                <ScrollViewer Grid.Row="1" Background="{DynamicResource ThemeContentBackground}" HorizontalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding SelectedCommitDiffLines}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:HistoryDiffLineViewModel">
                                <Border Background="{Binding BackgroundKey, Converter={StaticResource ResourceKeyBrushConverter}}">
                                    <TextBlock Text="{Binding Content}"
                                               Foreground="{Binding ForegroundKey, Converter={StaticResource ResourceKeyBrushConverter}}"
                                               FontFamily="Cascadia Code,Consolas,monospace"
                                               FontSize="{DynamicResource AppFontSize}"
                                               TextWrapping="NoWrap"
                                               Margin="8,0"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

        </Grid>
    </Grid>
</UserControl>
