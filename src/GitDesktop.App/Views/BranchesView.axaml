<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GitDesktop.App.ViewModels"
             x:Class="GitDesktop.App.Views.BranchesView"
             x:DataType="vm:BranchesViewModel">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="#1e1e1e" Padding="12,8">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Branches" FontWeight="Bold" FontSize="14"
                           VerticalAlignment="Center"/>
                <Button Content="↻ Refresh" Command="{Binding RefreshCommand}" Margin="8,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- Branch list -->
        <ListBox Grid.Row="1" ItemsSource="{Binding Branches}"
                 SelectedItem="{Binding SelectedBranch}"
                 Background="#1e1e1e" Margin="8">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <DockPanel>
                        <!-- Switch / Delete buttons for local non-current branches -->
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="4"
                                    IsVisible="{Binding IsLocal}">
                            <Button Content="Switch"
                                    Command="{Binding $parent[UserControl].((vm:BranchesViewModel)DataContext).SwitchBranchCommand}"
                                    CommandParameter="{Binding}"
                                    IsEnabled="{Binding !IsCurrentBranch}"
                                    Padding="6,2"/>
                            <Button Content="Delete"
                                    Command="{Binding $parent[UserControl].((vm:BranchesViewModel)DataContext).DeleteBranchCommand}"
                                    CommandParameter="{Binding}"
                                    IsEnabled="{Binding !IsCurrentBranch}"
                                    Foreground="#f48771" Padding="6,2"/>
                        </StackPanel>
                        <StackPanel Spacing="2" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="★" Foreground="#dcdcaa"
                                           IsVisible="{Binding IsCurrentBranch}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="[remote]" Foreground="#888" FontSize="11"
                                           IsVisible="{Binding IsRemote}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="{Binding TipHash}" Foreground="#888"
                                       FontFamily="Cascadia Code,Consolas,monospace"
                                       FontSize="11"/>
                        </StackPanel>
                    </DockPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Create-branch panel -->
        <Border Grid.Row="2" Background="#252526" Padding="12,8">
            <Grid RowDefinitions="Auto,Auto">
                <TextBlock Grid.Row="0" Text="{Binding StatusMessage}" Foreground="#888"
                           FontSize="12" Margin="0,0,0,4"
                           IsVisible="{Binding StatusMessage, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                <DockPanel Grid.Row="1">
                    <Button DockPanel.Dock="Right" Content="Create branch"
                            Command="{Binding CreateBranchCommand}" Margin="8,0,0,0"/>
                    <TextBox Text="{Binding NewBranchName}"
                             Watermark="New branch name…"/>
                </DockPanel>
            </Grid>
        </Border>

    </Grid>
</UserControl>
