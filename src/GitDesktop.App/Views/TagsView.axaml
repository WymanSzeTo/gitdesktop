<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GitDesktop.App.ViewModels"
             x:Class="GitDesktop.App.Views.TagsView"
             x:DataType="vm:TagsViewModel">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="#1e1e1e" Padding="12,8">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Tags" FontWeight="Bold" FontSize="14"
                           VerticalAlignment="Center"/>
                <Button Content="↻ Refresh" Command="{Binding RefreshCommand}" Margin="8,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- Tag list -->
        <ListBox Grid.Row="1" ItemsSource="{Binding Tags}"
                 SelectedItem="{Binding SelectedTag}"
                 Background="#1e1e1e" Margin="8">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Content="Delete"
                                Command="{Binding $parent[UserControl].((vm:TagsViewModel)DataContext).DeleteTagCommand}"
                                CommandParameter="{Binding}"
                                Foreground="#f48771" Padding="6,2"/>
                        <StackPanel Spacing="2" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="[annotated]" Foreground="#4ec9b0" FontSize="11"
                                           IsVisible="{Binding IsAnnotated}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="{Binding TargetHash}" Foreground="#888"
                                       FontFamily="Cascadia Code,Consolas,monospace"
                                       FontSize="11"/>
                            <TextBlock Text="{Binding Message}" Foreground="#ccc"
                                       FontSize="11" TextTrimming="CharacterEllipsis"
                                       IsVisible="{Binding Message, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                        </StackPanel>
                    </DockPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Create-tag panel -->
        <Border Grid.Row="2" Background="#252526" Padding="12,8">
            <Grid RowDefinitions="Auto,Auto,Auto,Auto">
                <TextBlock Grid.Row="0" Text="{Binding StatusMessage}" Foreground="#888"
                           FontSize="12" Margin="0,0,0,4"
                           IsVisible="{Binding StatusMessage, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                <TextBox Grid.Row="1" Text="{Binding NewTagName}"
                         Watermark="Tag name…" Margin="0,0,0,4"/>
                <TextBox Grid.Row="2" Text="{Binding NewTagMessage}"
                         Watermark="Tag message (for annotated tag)…" Margin="0,0,0,4"/>
                <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8"
                            HorizontalAlignment="Right">
                    <Button Content="Create lightweight tag"
                            Command="{Binding CreateLightweightTagCommand}"/>
                    <Button Content="Create annotated tag"
                            Command="{Binding CreateAnnotatedTagCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</UserControl>
